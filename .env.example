# Copy this file to .env and fill in your own values. .env is gitignored.

# Your Home Assistant URL, no trailing slash.
# Use the same address the tablet can reach — usually the local IP works
# better than a .local hostname on some Android WebViews.
VITE_HA_URL=http://homeassistant.local:8123

# Settings -> long-lived access tokens, create one, paste it here.
VITE_HA_TOKEN=
